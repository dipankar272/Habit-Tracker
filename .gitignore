# ============================================================
#  HABIT TRACKER — Root .gitignore
#  Covers: Node.js · React/Vite · AWS · macOS/Windows · Editors
# ============================================================

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# --- Build outputs ---
dist/
dist-ssr/
build/
.next/
out/

# --- Environment & Secrets (NEVER commit these) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.cert

# --- Database files (LowDB local data) ---
Backend/db.json

# --- AWS Credentials & Config (CRITICAL for AWS deployment) ---
.aws/
aws-exports.js
amplify/
#awsconfiguration.json
*.rsa
serverless.yml.bak
.serverless/
cdk.out/
cdk.context.json
samconfig.toml

# --- Terraform (if used for IaC on AWS) ---
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl

# --- OS files ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Editors ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# --- Vercel / Netlify / CI ---
.vercel
.netlify

# --- Misc ---
*.local
*.bak
*.tmp
coverage/
.nyc_output/
